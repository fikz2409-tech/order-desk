# Railway sets DATABASE_URL automatically when you add a PostgreSQL service.
# For local testing only, point this at a local Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/orderdesk

# Shared passwords for each role. CHANGE THESE before going live.
SALES_PASSWORD=changeme-sales
ADMIN_PASSWORD=changeme-admin

# Railway sets PORT automatically; only needed for local runs.
PORT=3000
